# =============================================================================
# ONLY these 2 variables need to be set in Coolify's Environment panel.
# Everything else (DB host, port, Redis URLs, site name) is hardcoded in
# docker-compose.yml using container names and does not need to be set here.
# =============================================================================

# MariaDB root password — used by both mariadb container and bench new-site
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# ERPNext administrator password — used once during: bench new-site
ADMIN_PASSWORD=CHANGE_THIS_STRONG_ADMIN_PASSWORD
