# Copy this file to .env and set real values
# NEVER commit .env to git — it has passwords

# ── Site ─────────────────────────────────────────────────────────────────────
FRAPPE_SITE_NAME_HEADER=erp.prashang.com

# ── MariaDB ──────────────────────────────────────────────────────────────────
DB_HOST=mariadb
DB_PORT=3306
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# ── Redis (use container names — no changes needed) ───────────────────────────
REDIS_CACHE=redis-cache:6379
REDIS_QUEUE=redis-queue:6379

# ── ERPNext admin login ───────────────────────────────────────────────────────
# Used only once: bench new-site command after first deploy
ADMIN_PASSWORD=CHANGE_THIS_STRONG_ADMIN_PASSWORD
